@page "/"
@using Microsoft.Data.SqlClient
@using Dapper
@using BCrypt.Net
@inject IConfiguration Config
@inject NavigationManager NavManager
@rendermode InteractiveServer

<RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 80vh;">
    <RadzenCard class="rz-my-12 rz-mx-auto rz-p-12" style="max-width: 500px; width: 100%;">
        <RadzenText TextStyle="TextStyle.H4" Class="rz-text-align-center rz-mb-6">Accedi</RadzenText>
        
        @if (!string.IsNullOrEmpty(messaggio))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Class="rz-mb-4">@messaggio</RadzenAlert>
        }

        <RadzenLogin AllowRegister="true" AllowRememberMe="false"
                     Login="@OnLogin"
                     Register="@(() => NavManager.NavigateTo("/signup"))"
                     LoginText="ENTRA" RegisterText="Crea account" />
    </RadzenCard>
</RadzenStack>

@code {
    private string messaggio = "";

    async Task OnLogin(LoginArgs args)
    {
        try
        {
            using (var db = new SqlConnection(Config.GetConnectionString("DefaultConnection")))
            {
                var sql = "SELECT Password FROM dbo.Utenti WHERE Email = @User";
                var riga = await db.QueryFirstOrDefaultAsync<dynamic>(sql, new { User = args.Username });

                if (riga != null && BCrypt.Verify(args.Password, (string)riga.Password))
                {
                    NavManager.NavigateTo("/home");
                }
                else
                {
                    messaggio = "Email o Password errati.";
                }
            }
        }
        catch (Exception ex)
        {
            messaggio = "Errore: " + ex.Message;
        }
    }
}