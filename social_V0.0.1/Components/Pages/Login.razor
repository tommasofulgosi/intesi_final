@page "/login"
@using Microsoft.Data.SqlClient
@using Dapper
@using BCrypt.Net
@inject IConfiguration Config
@inject NavigationManager NavManager

<PageTitle>Login</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 card p-4 shadow">
            <h3 class="text-center">Accedi al Social</h3>

            <div class="mb-3">
                <label>Username</label>
                <input class="form-control" @bind="usernameLogin" placeholder="Inserisci username" />
            </div>

            <div class="mb-3">
                <label>Password</label>
                <input type="password" class="form-control" @bind="passwordLogin" placeholder="Inserisci password" />
            </div>

            <button class="btn btn-success w-100" @onclick="EseguiLogin">Entra</button>

            @if (!string.IsNullOrEmpty(messaggio))
            {
                <div class="alert @classeMessaggio mt-3">@messaggio</div>
            }
        </div>
    </div>
</div>

@rendermode InteractiveServer

@code {
    private string usernameLogin = "";
    private string passwordLogin = "";
    private string messaggio = "";
    private string classeMessaggio = "alert-danger";

    private async Task EseguiLogin()
    {
        try
        {
            string connectionString = Config.GetConnectionString("DefaultConnection") ?? "";

            using (var db = new SqlConnection(connectionString))
            {
                // 1. Cerchiamo l'utente nel database tramite lo username
                var sql = "SELECT * FROM Utenti WHERE Username = @User";
                var utenteTrovato = await db.QueryFirstOrDefaultAsync<Utente>(sql, new { User = usernameLogin });

                if (utenteTrovato != null)
                {
                    // 2. L'utente esiste! Ora verifichiamo la password con BCrypt
                    // NOTA: Se avevi salvato password in chiaro (come il tuo primo test), 
                    // Verify darà errore. Funziona solo con quelle criptate con HashPassword.
                    bool passwordValida = BCrypt.Verify(passwordLogin, utenteTrovato.PasswordHash);

                    if (passwordValida)
                    {
                        messaggio = "Login effettuato! Reindirizzamento...";
                        classeMessaggio = "alert-success";
                        StateHasChanged();

                        // Aspettiamo 2 secondi e andiamo alla Home
                        await Task.Delay(2000);
                        NavManager.NavigateTo("/");
                    }
                    else
                    {
                        messaggio = "Password errata!";
                        classeMessaggio = "alert-danger";
                    }
                }
                else
                {
                    messaggio = "Utente non trovato!";
                    classeMessaggio = "alert-danger";
                }
            }
        }
        catch (Exception ex)
        {
            messaggio = "Errore di connessione: " + ex.Message;
            classeMessaggio = "alert-danger";
        }
    }
}