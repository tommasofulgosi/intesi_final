@page "/"
@page "/login"
@using Microsoft.Data.SqlClient
@using Dapper
@using BCrypt.Net
@using social_V0._0._1.Models
@using social_V0._0._1.Services
@inject IConfiguration Config
@inject NavigationManager NavManager
@inject SessionService Session
@rendermode InteractiveServer

<RadzenCard class="rz-shadow-10 rz-p-12" style="max-width: 450px; width: 90%; border-radius: 15px; background-color: white;">
    
    @* Titolo che usa il blu della tua palette Intesi *@
    <RadzenText TextStyle="TextStyle.H4" Class="rz-text-align-center rz-mb-6"
                Style="font-weight: 800; color: var(--brand-primary); font-family: 'Segoe UI', sans-serif;">
        Accedi
    </RadzenText>
    
    @if (!string.IsNullOrEmpty(messaggio))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Class="rz-mb-4" Variant="Variant.Flat">@messaggio</RadzenAlert>
    }

    @* RadzenLogin personalizzato per i colori della palette *@
    <RadzenLogin UserText="Email"
                 AllowRegister="true"
                 AllowRememberMe="false"
                 Login="@OnLogin"
                 Register="@(() => NavManager.NavigateTo("/signup"))"
                 ResetPasswordText="Password dimenticata?"
                 LoginText="Accedi"
                 RegisterMessageText="Non sei registrato?"
                 RegisterText="Crea account"
                 Style="--rz-primary: var(--brand-action); --rz-button-primary-background-color: var(--brand-primary); --rz-button-border-radius: 10px;" />

    <div style="text-align: center; margin-top: 20px; border-top: 1px solid var(--brand-border); padding-top: 20px;">
        <RadzenLink Text="Termini e condizioni" Path="/eula"
                    Style="font-size: 0.9rem; color: var(--brand-action); font-weight: 600;" />
    </div>
</RadzenCard>

@code {
    private string messaggio = "";

    async Task OnLogin(LoginArgs args)
    {
        try
        {
            using (var db = new SqlConnection(Config.GetConnectionString("DefaultConnection")))
            {
                var sql = "SELECT * FROM dbo.Utenti WHERE Email = @User";
                var utente = await db.QueryFirstOrDefaultAsync<Utente>(sql, new { User = args.Username });

                if (utente != null && BCrypt.Verify(args.Password, utente.Password))
                {
                    Session.Login(utente);
                    NavManager.NavigateTo("/home");
                }
                else
                {
                    messaggio = "Email o Password errati.";
                }
            }
        }
        catch (Exception ex)
        {
            messaggio = "Errore di connessione al database.";
        }
    }
}