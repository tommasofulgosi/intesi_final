@page "/signup"
@using Microsoft.Data.SqlClient
@using Dapper
@using BCrypt.Net
@using social_V0._0._1.Models
@using System.IO
@inject IConfiguration Config
@inject NavigationManager NavManager
@inject IWebHostEnvironment Env
@rendermode InteractiveServer

<RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 80vh; padding: 2rem;">
    <RadzenCard class="rz-shadow-10 rz-p-12" style="max-width: 600px; width: 100%;">
        <RadzenText TextStyle="TextStyle.H4" Class="rz-text-align-center rz-mb-6">Registrazione</RadzenText>

        @if (!string.IsNullOrEmpty(messaggio))
        {
            <RadzenAlert AlertStyle="@(successo ? AlertStyle.Success : AlertStyle.Danger)" Variant="Variant.Flat" Class="rz-mb-4">@messaggio</RadzenAlert>
        }

        <RadzenTemplateForm TItem="Utente" Data="@nuovoUtente" Submit="@OnSignup">
            <RadzenStack Gap="1.5rem">
                
                <RadzenRow>
                    <RadzenColumn Size="6">
                        <RadzenFormField Text="Nome *" Style="width:100%">
                            <RadzenTextBox @bind-Value="@nuovoUtente.Nome" Name="Nome" Style="width: 100%;" />
                            <RadzenRequiredValidator Component="Nome" Text="Richiesto" />
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenFormField Text="Cognome *" Style="width:100%">
                            <RadzenTextBox @bind-Value="@nuovoUtente.Cognome" Name="Cognome" Style="width: 100%;" />
                            <RadzenRequiredValidator Component="Cognome" Text="Richiesto" />
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenFormField Text="Email *" Style="width:100%">
                    <RadzenTextBox @bind-Value="@nuovoUtente.Email" Name="Email" Style="width: 100%;" />
                    <RadzenRequiredValidator Component="Email" Text="Richiesto" />
                    <RadzenEmailValidator Component="Email" Text="Email non valida" />
                </RadzenFormField>

                <RadzenFormField Text="Password *" Style="width:100%">
                    <RadzenPassword @bind-Value="@nuovoUtente.Password" Name="Password" Style="width: 100%;" />
                    <RadzenRequiredValidator Component="Password" Text="Richiesto" />
                </RadzenFormField>

                <RadzenRow>
                    <RadzenColumn Size="6">
                        <RadzenFormField Text="Dipartimento" Style="width:100%">
                            <RadzenTextBox @bind-Value="@nuovoUtente.Dipartimento" MaxLength="50" Style="width: 100%;" />
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenFormField Text="Data di Nascita" Style="width:100%">
                            @* DISABILITATO ORARIO E FORMATO SOLO DATA *@
                            <RadzenDatePicker @bind-Value="@nuovoUtente.DataDiNascita"
                                              DateFormat="dd/MM/yyyy"
                                              ShowTime="false"
                                              Style="width:100%" />
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenText TextStyle="TextStyle.Subtitle2">Foto Profilo (Opzionale)</RadzenText>
                <RadzenUpload ChooseText="Seleziona Foto"
                              Accept="image/*"
                              Auto="false"
                              Multiple="false"
                              Change="@OnUploadChange"
                              Style="width: 100%" />

                <RadzenButton ButtonType="ButtonType.Submit" Text="REGISTRATI" Style="width: 100%" />
                <RadzenButton ButtonStyle="ButtonStyle.Light" Text="TORNA AL LOGIN" Click="@(() => NavManager.NavigateTo("/login"))" Style="width: 100%" />
            </RadzenStack>
        </RadzenTemplateForm>
    </RadzenCard>
</RadzenStack>

@code {
    private Utente nuovoUtente = new Utente();
    private string messaggio = "";
    private bool successo = false;
    private string? nomeFile;

    void OnUploadChange(UploadChangeEventArgs args)
    {
        var file = args.Files.FirstOrDefault();
        if (file != null)
        {
            nomeFile = file.Name;
        }
    }

    async Task OnSignup()
    {
        try
        {
            if (!string.IsNullOrEmpty(nomeFile))
            {
                nuovoUtente.FotoUrl = "/uploads/" + Guid.NewGuid() + "_" + nomeFile;
            }

            string hash = BCrypt.HashPassword(nuovoUtente.Password);

            using (var db = new SqlConnection(Config.GetConnectionString("DefaultConnection")))
            {
                var sql = @"INSERT INTO dbo.Utenti (Nome, Cognome, Email, Password, Dipartimento, DataDiNascita, DataCreazione, FotoUrl) 
                            VALUES (@Nome, @Cognome, @Email, @Password, @Dipartimento, @DataDiNascita, @DataCreazione, @FotoUrl)";
                
                await db.ExecuteAsync(sql, new
                {
                    nuovoUtente.Nome,
                    nuovoUtente.Cognome,
                    nuovoUtente.Email,
                    Password = hash,
                    nuovoUtente.Dipartimento,
                    // SQL gestirà bene il DateTime? anche se la colonna è DATE
                    nuovoUtente.DataDiNascita,
                    DataCreazione = DateTime.Now,
                    nuovoUtente.FotoUrl
                });

                successo = true;
                messaggio = "Registrazione completata!";
                StateHasChanged();
                await Task.Delay(1500);
                NavManager.NavigateTo("/");
            }
        }
        catch (Exception ex)
        {
            successo = false;
            messaggio = "Errore: " + ex.Message;
        }
    }
}