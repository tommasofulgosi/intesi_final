@page "/signup"
@rendermode InteractiveServer
@using social_V0.0.1.Models
@using Microsoft.Data.SqlClient
@using Dapper
@inject IConfiguration Config

<h3>Registrazione Nuovo Utente</h3>

<div class="col-md-4">
    <div class="mb-3">
        <label>Username</label>
        <input class="form-control" @bind="nuovoUtente.Username" />
    </div>
    <div class="mb-3">
        <label>Email</label>
        <input class="form-control" @bind="nuovoUtente.Email" />
    </div>
    <div class="mb-3">
        <label>Password</label>
        <input type="password" class="form-control" @bind="passwordChiara" />
    </div>
    <button class="btn btn-primary" @onclick="RegistraUtente">Registrati</button>
    
    @if (!string.IsNullOrEmpty(messaggio))
    {
        <p class="mt-3 alert alert-info">@messaggio</p>
    }
</div>

@code {
    private Utente nuovoUtente = new Utente();
    private string passwordChiara = "";
    private string messaggio = "";

    private async Task RegistraUtente()
    {
        try
        {
            string connectionString = Config.GetConnectionString("DefaultConnection") ?? "";
            
            string passwordCriptata = BCrypt.Net.BCrypt.HashPassword(passwordChiara);

            using (var db = new SqlConnection(connectionString))
            {
                var sql = "INSERT INTO Utenti (Username, PasswordHash, Email) VALUES (@Username, @Pass, @Email)";
    
                var parametri = new
                {
                    Username = nuovoUtente.Username,
                    Pass = passwordCriptata,
                    Email = nuovoUtente.Email
                };
    
                await db.ExecuteAsync(sql, parametri);
                messaggio = "Utente registrato con password sicura!";
            }
        }
        catch (Exception ex)
        {
            messaggio = "Errore: " + ex.Message;
        }
    }
}