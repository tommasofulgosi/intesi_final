@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<RadzenText Text="Counter" TextStyle="TextStyle.H3" TagName="TagName.H1" />

<RadzenCard class="rz-my-12 rz-mx-auto" Style="max-width: 420px;">
    <RadzenText TextStyle="TextStyle.Subtitle1">Current count: @currentCount</RadzenText>
    <RadzenButton Click=@IncrementCount Text="Click me" ButtonStyle="ButtonStyle.Primary" />
</RadzenCard>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}