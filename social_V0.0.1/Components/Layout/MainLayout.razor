@inherits LayoutComponentBase
@using Radzen.Blazor

<RadzenComponents @rendermode="InteractiveServer" />

<div class="main-container">
    <RadzenHeader Style="height: 65px; background: rgba(255,255,255,0.9); backdrop-filter: blur(5px); display: flex; align-items: center; padding: 0 20px; border-bottom: 1px solid rgba(0,0,0,0.1);">
        <div style="display: grid; grid-template-columns: 1fr 2fr 1fr; width: 100%; align-items: center;">
            
            <div style="display: flex; align-items: center; gap: 10px;">
                <RadzenIcon Icon="hub" Style="color: #0866FF; font-size: 2rem;" />
                <RadzenText Text="SocialIntesi" TextStyle="TextStyle.H6" Style="margin:0; font-weight:bold; color:#0866FF;" />
            </div>

            <div style="display: flex; justify-content: center;">
                <div style="position: relative; width: 100%; max-width: 400px;">
                    <RadzenIcon Icon="search" Style="position: absolute; left: 15px; top: 10px; color: #65676b; z-index: 5;" />
                    <RadzenTextBox Placeholder="Cerca..."
                                   Style="width: 100%; border-radius: 50px; padding-left: 45px; background-color: #f0f2f5; border: none; height: 40px;" />
                </div>
            </div>

            <div style="display: flex; justify-content: flex-end;">
                <RadzenButton Text="Accedi" ButtonStyle="ButtonStyle.Primary" />
            </div>
        </div>
    </RadzenHeader>

    <div class="center-content">
        @Body
    </div>
</div>